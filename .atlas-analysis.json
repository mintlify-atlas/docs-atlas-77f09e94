  "keyFeatures": [
    "Automated Amazon price monitoring",
    "Instant price drop notifications via Telegram",
    "Interactive product management with inline buttons",
    "Price history charts and analytics",
    "Daily summary reports",
    "Multi-chat support with persistent data storage",
    "Scheduled price checks every 2 hours",
    "Lowest price tracking for each product"
  ],
  "publicApiSurface": [
    "/start - Show welcome message and command list",
    "/add [URL] - Add Amazon product to tracking list",
    "/list - View all tracked products with interactive menu",
    "/check - Manually trigger price check for all products",
    "/remove [URL] - Remove product from tracking",
    "/edit [old_url] [new_url] - Update product URL",
    "/stats - View tracking statistics and savings",
    "/chart [URL] - Generate price history chart",
    "/help - Display command guide"
  ]
